    try:
        clf = PTClassifier(RCoMET(n_ch, n_classes), name="GTA+RCoMET")
        clf.fit(X_gta[src_idx], y_src_full)
        P = clf.predict_proba(X_gta[tgt_idx])
        results.append({"subject": target, "method": "GTA+RCoMET",
                        "balanced_acc": _bacc(y_tgt, P), "f1": _f1(y_tgt, P)})
        print(f"  GTA+RCoMET: {_bacc(y_tgt, P):.3f}")
    except Exception as e:
        print(f"  GTA+RCoMET FAILED: {e}")

    # 7. EA+GTA+RCoMET (فعلاً کامنت)
    try:
        clf = PTClassifier(RCoMET(n_ch, n_classes), name="EA+GTA+RCoMET")
        clf.fit(X_eagta[src_idx], y_src_full)
        P = clf.predict_proba(X_eagta[tgt_idx])
        results.append({"subject": target, "method": "EA+GTA+RCoMET",
                        "balanced_acc": _bacc(y_tgt, P), "f1": _f1(y_tgt, P)})
        print(f"  EA+GTA+RCoMET: {_bacc(y_tgt, P):.3f}")
    except Exception as e:
        print(f"  EA+GTA+RCoMET FAILED: {e}")

    # Save after each subject
    df = pd.DataFrame(results)
    df.to_csv(os.path.join(save_dir, "metrics.csv"), index=False)
    print(f"\n  Current means:")
    print(df.groupby("method")["balanced_acc"].mean().round(3)
          .sort_values(ascending=False).to_string())

# ── Final ─────────────────────────────────────────────────────
summary = pd.DataFrame(results)
summary.to_csv("summary_all_datasets.csv", index=False)
print("\n✅ Benchmark complete!")
