# ── GPU SPD Math ──────────────────────────────────────────────
def torch_logm_batch(X):
    eigvals, eigvecs = torch.linalg.eigh(X)
    eigvals = eigvals.clamp(min=_EIG_FLOOR)
    return (eigvecs * torch.log(eigvals).unsqueeze(-2)) @ eigvecs.transpose(-1, -2)

def torch_invsqrtm_batch(X):
    eigvals, eigvecs = torch.linalg.eigh(X)
    eigvals = eigvals.clamp(min=_EIG_FLOOR)
    return (eigvecs * (eigvals ** -0.5).unsqueeze(-2)) @ eigvecs.transpose(-1, -2)

def torch_sqrtm_batch(X):
    eigvals, eigvecs = torch.linalg.eigh(X)
    eigvals = eigvals.clamp(min=_EIG_FLOOR)
    return (eigvecs * (eigvals ** 0.5).unsqueeze(-2)) @ eigvecs.transpose(-1, -2)

def geodesic_distance_torch(C1, C2):
    W    = torch_invsqrtm_batch(C1)
    M    = W @ C2 @ W
    eigv, _ = torch.linalg.eigh(M)
    eigv = eigv.clamp(min=_EIG_FLOOR)
    return torch.log(eigv).pow(2).sum().sqrt()

print("✓ GPU SPD Math OK")

# ── CPU SPD Math ──────────────────────────────────────────────
def _eigh_logm(C):
    w, v = np.linalg.eigh(C)
    w = np.maximum(w, _EIG_FLOOR)
    return v @ np.diag(np.log(w)) @ v.T

def _sqrtm(C):
    w, v = np.linalg.eigh(C)
    w = np.maximum(w, _EIG_FLOOR)
    return v @ np.diag(w ** 0.5) @ v.T

def _invsqrtm(C):
    w, v = np.linalg.eigh(C)
    w = np.maximum(w, _EIG_FLOOR)
    return v @ np.diag(w ** -0.5) @ v.T

def _eigh_expm(L):
    w, v = np.linalg.eigh(L)
    return v @ np.diag(np.exp(w)) @ v.T

print("✓ CPU SPD Math OK")

# ── compute_csd_spd ───────────────────────────────────────────
def _process_single_trial(x_trial, sfreq, freq_bands, nperseg, reg, n_ch, n_bands):
    eye_reg = reg * np.eye(n_ch)
    out_trial = np.empty((n_bands, n_ch, n_ch), dtype=np.float32)
    for bi, (_, f_lo, f_hi) in enumerate(freq_bands):
        C = np.zeros((n_ch, n_ch), dtype=np.float64)
        for i in range(n_ch):
            for j in range(i, n_ch):
                freqs, Pxy = scipy_csd(
                    x_trial[i], x_trial[j], fs=sfreq, nperseg=nperseg,
                    window="hann", scaling="density", detrend="constant",
                )
                mask = (freqs >= f_lo) & (freqs <= f_hi)
                val  = float(np.mean(np.real(Pxy[mask]))) if mask.sum() > 0 else 0.0
                C[i, j] = val
                C[j, i] = val
        C += eye_reg
        C  = 0.5 * (C + C.T)
        out_trial[bi] = C.astype(np.float32)
    return out_trial

def compute_csd_spd(X, sfreq, freq_bands=None, reg=1e-4, nperseg=None):
    if freq_bands is None:
        freq_bands = FREQ_BANDS
    n_trials, n_ch, _ = X.shape
    n_bands = len(freq_bands)
    if nperseg is None:
        nperseg = max(64, int(sfreq // 2))
    results = Parallel(n_jobs=-1)(
        delayed(_process_single_trial)(
            X[ti].astype(np.float64), sfreq, freq_bands,
            nperseg, reg, n_ch, n_bands
        ) for ti in range(n_trials)
    )
    gc.collect()
    return np.stack(results)

print("✓ compute_csd_spd OK")

# ── EA alignment (per-subject) ────────────────────────────────
def ea_align_global(X_cov, metadata):
    print("  EA alignment (GPU)...")
    X   = torch.tensor(X_cov, dtype=torch.float32, device=DEVICE)
    out = torch.empty_like(X)
    for subj in metadata["subject"].unique():
        idx   = np.where(metadata["subject"].values == subj)[0]
        idx_t = torch.tensor(idx, device=DEVICE)
        for bi in range(N_BANDS):
            R = X[idx_t, bi].mean(0)
            W = torch_invsqrtm_batch(R)
            out[idx_t, bi] = W @ X[idx_t, bi] @ W.T
    result = out.cpu().numpy().astype(np.float32)
    del X, out
    torch.cuda.empty_cache()
    gc.collect()
    print("  ✓ EA done")
    return result

# ── Tangent Features + PCA ────────────────────────────────────
def _compute_raw_tangent(X_cov):
    X = torch.tensor(X_cov, dtype=torch.float32, device=DEVICE)
    n, nb, d, _ = X.shape
    idx   = torch.triu_indices(d, d)
    scale = torch.ones(len(idx[0]), device=DEVICE)
    scale[idx[0] != idx[1]] = np.sqrt(2)
    feats = []
    for bi in range(nb):
        logs = torch_logm_batch(X[:, bi])
        ref  = logs.mean(0)
        S    = logs - ref
        F    = S[:, idx[0], idx[1]] * scale
        feats.append(F)
    result = torch.cat(feats, dim=1).cpu().numpy().astype(np.float32)
    del X
    torch.cuda.empty_cache()
    gc.collect()
    return result

def tangent_features_global(X_cov, n_components=TV_N_COMPONENTS):
    print("  Tangent Features (GPU + PCA)...")
    raw = _compute_raw_tangent(X_cov)
    n_components = min(n_components, raw.shape[0]-1, raw.shape[1])
    pca = PCA(n_components=n_components, random_state=42)
    result = pca.fit_transform(raw).astype(np.float32)
    var_explained = pca.explained_variance_ratio_.sum()
    print(f"  ✓ Tangent {raw.shape[1]} → {n_components} dims ({var_explained:.1%} var)")
    return result, pca

def apply_tangent_pca(X_cov, pca):
    raw = _compute_raw_tangent(X_cov)
    return pca.transform(raw).astype(np.float32)

