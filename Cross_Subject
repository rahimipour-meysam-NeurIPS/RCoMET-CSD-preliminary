    except Exception as e:
        print(f"  RCoMET FAILED: {e}")

    # 5. EA+RCoMET
    try:
        clf = PTClassifier(RCoMET(n_ch, n_classes), name="EA+RCoMET")
        clf.fit(Xea_s1, y_s1)
        P  = clf.predict_proba(Xea_s2)
        ba = _bacc(y_s2, P)
