            probas.append(mdm.predict_proba(X_s2[:, bi].astype(np.float64)))
        P = np.mean(probas, axis=0)
        ba = _bacc(y_s2, P)
        results.append({"subject": subj, "method": "MDM-LE",
                        "balanced_acc": ba, "f1": _f1(y_s2, P),
                        "session_train": sessions[0], "session_test": sessions[1]})
        print(f"  MDM-LE: {ba:.3f}")
    except Exception as e:
        print(f"  MDM-LE FAILED: {e}")

    # 2. TS+SVM
    try:
        clf = SVC(kernel="linear", C=1.0, probability=False, random_state=42)
        clf.fit(TV_s1, y_s1)
        pred = clf.predict(TV_s2)
        P    = np.eye(n_classes)[pred]
        ba   = _bacc(y_s2, P)
        results.append({"subject": subj, "method": "TS+SVM",
                        "balanced_acc": ba, "f1": _f1(y_s2, P),
