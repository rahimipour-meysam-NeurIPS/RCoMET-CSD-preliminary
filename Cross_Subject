def subsample_src(idx, y, max_n=500, seed=42):
    if len(idx) <= max_n:
        return idx
    rng         = np.random.default_rng(seed)
    classes     = np.unique(y[idx])
    n_per_class = max_n // len(classes)
    selected    = []
    for c in classes:
        c_idx = idx[y[idx] == c]
        n     = min(n_per_class, len(c_idx))
        selected.append(rng.choice(c_idx, n, replace=False))
    return np.concatenate(selected)

