# ── RCoMET Model ──────────────────────────────────────────────
class _LogEuclideanLayer(nn.Module):
    def forward(self, cov):
        B, nb, d, _ = cov.shape
        x = cov.reshape(B * nb, d, d)
        return torch_logm_batch(x).reshape(B, nb, d, d)

class _MambaEncoder(nn.Module):
    def __init__(self, input_dim):
        super().__init__()
        self.input_proj   = nn.Linear(input_dim, RCOMET_D_MODEL)
        self.mamba_layers = nn.ModuleList([
            Mamba(d_model=RCOMET_D_MODEL, d_state=RCOMET_D_STATE,
                  d_conv=RCOMET_D_CONV, expand=RCOMET_EXPAND)
            for _ in range(RCOMET_LAYERS)
        ])
        self.norm_layers = nn.ModuleList([
            nn.LayerNorm(RCOMET_D_MODEL) for _ in range(RCOMET_LAYERS)
        ])
        self.dropout = nn.Dropout(RCOMET_DROPOUT)
        self.pool    = nn.AdaptiveAvgPool1d(1)

    def forward(self, x):
        x = self.input_proj(x)
        for mamba, norm in zip(self.mamba_layers, self.norm_layers):
            residual = x
            x = norm(x)
            x = mamba(x)
            x = self.dropout(x)
            x = x + residual
        return self.pool(x.transpose(1, 2)).squeeze(-1)

class RCoMET(nn.Module):
    def __init__(self, channels, n_classes):
        super().__init__()
        self.log_euclidean = _LogEuclideanLayer()
        self.encoder       = _MambaEncoder(channels)
        self.classifier    = nn.Linear(RCOMET_D_MODEL, n_classes)

    def forward(self, cov):
        B, nb, d, _ = cov.shape
        x = self.log_euclidean(cov)
        x = x.view(B, nb * d, d)
        x = self.encoder(x)
        return self.classifier(x)

print("✓ RCoMET OK")

# ── Manifold Loss (WP1 contribution) ─────────────────────────
def manifold_regularization_loss(X_batch, session_labels):
    sessions = torch.unique(session_labels)
    if len(sessions) < 2:
        return torch.tensor(0.0, device=DEVICE)
    loss = torch.tensor(0.0, device=DEVICE)
    n_pairs = 0
    for bi in range(N_BANDS):
        means = []
        for s in sessions:
            mask = session_labels == s
            if mask.sum() > 0:
                means.append(X_batch[mask, bi].mean(0))
        for i in range(len(means)):
            for j in range(i+1, len(means)):
                loss += geodesic_distance_torch(means[i], means[j])
                n_pairs += 1
    return loss / max(n_pairs, 1)

print("✓ Manifold Loss OK")

# ── Geodesic Augmentation ─────────────────────────────────────
def geodesic_augment_multiband(X, y, aug_ratio=0.1,
                                subset_size=128, max_aug=16, rng=None):
    if aug_ratio <= 0:
        return X, y
    if rng is None:
        rng = np.random.default_rng()
    n, nb, d, _ = X.shape
    reg_eye     = 1e-4 * np.eye(d)
    subset_size = min(subset_size, n)
    subset_idx  = rng.choice(n, size=subset_size, replace=False)
    X_sub = X[subset_idx]
    y_sub = np.asarray(y)[subset_idx]
    n_aug     = min(max_aug, max(4, int(subset_size * aug_ratio)))
    class_idx = {c: np.where(y_sub == c)[0] for c in np.unique(y_sub)}
    valid_cls = [c for c, idx in class_idx.items() if len(idx) >= 2]
    if not valid_cls:
        return X, y
    X_syn, y_syn = [], []
    for _ in range(n_aug):
        cls   = valid_cls[rng.integers(len(valid_cls))]
        idx   = class_idx[cls]
        i, j  = rng.choice(idx, size=2, replace=False)
        alpha = float(rng.uniform(0.1, 0.9))
        C_syn = np.empty((nb, d, d), dtype=np.float32)
        valid = True
        for bi in range(nb):
            try:
                A = X_sub[i, bi].astype(np.float64) + reg_eye
                B = X_sub[j, bi].astype(np.float64) + reg_eye
                A_sqrt  = _sqrtm(A)
                A_isqrt = _invsqrtm(A)
                M       = A_isqrt @ B @ A_isqrt
                w, v    = np.linalg.eigh(M)
                w       = np.clip(w, _EIG_FLOOR, None)
                M_alpha = (v * (w ** alpha)) @ v.T
                C       = A_sqrt @ M_alpha @ A_sqrt
                C       = 0.5 * (C + C.T) + reg_eye
                if not np.isfinite(C).all():
                    valid = False
                    break
                C_syn[bi] = C.astype(np.float32)
            except Exception:
                valid = False
                break
        if valid:
            X_syn.append(C_syn)
            y_syn.append(cls)
    if not X_syn:
        return X, y
    X_aug = np.concatenate([X, np.stack(X_syn)])
    y_aug = np.concatenate([y, np.array(y_syn, dtype=np.asarray(y).dtype)])
    return X_aug, y_aug

print("✓ Geodesic Augmentation OK")

# ── PTClassifier با Manifold Loss ─────────────────────────────
class PTClassifier:
    def __init__(self, model, name="RCoMET", use_manifold_loss=False):
        self.model              = model.to(DEVICE)
        self.name               = name
        self.use_manifold_loss  = use_manifold_loss

    def _condition(self, X):
        X   = np.asarray(X, dtype=np.float64)
        nb  = X.shape[1]
        d   = X.shape[-1]
        eye = np.eye(d)
        for bi in range(nb):
            tr = np.mean(np.trace(X[:, bi], axis1=-2, axis2=-1))
            if tr > 0:
                X[:, bi] = X[:, bi] * (d / tr)
            X[:, bi] += 1e-4 * eye
        return X.astype(np.float32)

    def fit(self, X, y, session_labels=None):
        if RCOMET_AUG_RATIO > 0:
            rng  = np.random.default_rng(42)
            X, y = geodesic_augment_multiband(
                X, np.asarray(y),
                aug_ratio=RCOMET_AUG_RATIO,
                subset_size=AUG_SUBSET_SIZE,
                max_aug=AUG_MAX_SAMPLES,
                rng=rng,
            )
            if session_labels is not None:
                aug_n = len(X) - len(session_labels)
                session_labels = np.concatenate([
                    session_labels,
                    np.zeros(aug_n, dtype=session_labels.dtype)
                ])

        X  = self._condition(X)
        self.model.train()
        Xt = torch.as_tensor(X)
        yt = torch.as_tensor(np.asarray(y, dtype=np.int64))
        st = torch.as_tensor(session_labels) if session_labels is not None else None

        loader = DataLoader(
            TensorDataset(Xt, yt) if st is None
            else TensorDataset(Xt, yt, st),
            batch_size=RCOMET_BATCH, shuffle=True,
            pin_memory=True, num_workers=0
        )

        opt    = optim.AdamW(self.model.parameters(),
                             lr=RCOMET_LR, weight_decay=1e-4)
        crit   = nn.CrossEntropyLoss()
        scaler = torch.cuda.amp.GradScaler()

        print(f"    [{self.name}] {len(X)} trials, {RCOMET_EPOCHS} epochs...")
        for ep in range(RCOMET_EPOCHS):
            running_loss = 0.0
            for batch in loader:
                if st is not None:
                    bx, by, bs = batch
                    bs = bs.to(DEVICE, non_blocking=True)
                else:
                    bx, by = batch
                    bs = None

                bx = bx.to(DEVICE, non_blocking=True)
                by = by.to(DEVICE, non_blocking=True)
                opt.zero_grad()

                with torch.cuda.amp.autocast():
                    out  = self.model(bx)
                    loss = crit(out, by)
                    if self.use_manifold_loss and bs is not None:
                        loss += LAMBDA_MANIFOLD * manifold_regularization_loss(bx, bs)

                scaler.scale(loss).backward()
                scaler.unscale_(opt)
                nn.utils.clip_grad_norm_(self.model.parameters(), 1.0)
                scaler.step(opt)
                scaler.update()
                running_loss += loss.item()

            if (ep + 1) % 5 == 0:
                print(f"    Epoch {ep+1:02d}/{RCOMET_EPOCHS} | loss={running_loss/len(loader):.4f}")
        return self

    def predict_proba(self, X):
        X = self._condition(X)
        self.model.eval()
        with torch.no_grad(), torch.cuda.amp.autocast():
            out = self.model(torch.as_tensor(X).to(DEVICE))
        return torch.softmax(out, dim=1).cpu().numpy()

print("✓ PTClassifier OK")

# ── WP2 Metrics ───────────────────────────────────────────────
def geodesic_distance_preservation(X_s1, X_s2, n_pairs=100, seed=42):
    rng = np.random.default_rng(seed)
    n   = min(len(X_s1), len(X_s2), 50)
    idx1 = rng.choice(len(X_s1), n, replace=False)
    idx2 = rng.choice(len(X_s2), n, replace=False)

    X1 = torch.tensor(X_s1[idx1, 0], dtype=torch.float32, device=DEVICE)
    X2 = torch.tensor(X_s2[idx2, 0], dtype=torch.float32, device=DEVICE)

    dists1, dists2 = [], []
    for i in range(n):
        for j in range(i+1, n):
            d1 = geodesic_distance_torch(X1[i], X1[j]).item()
            d2 = geodesic_distance_torch(X2[i], X2[j]).item()
            dists1.append(d1)
            dists2.append(d2)

    if len(dists1) < 2:
        return 0.0

    r, _ = pearsonr(dists1, dists2)
    return float(r)

